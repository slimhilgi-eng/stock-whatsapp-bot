# ── Alpha Vantage ─────────────────────────────────────────────
# Kostenloser Key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=DEIN_ALPHA_VANTAGE_KEY

# ── WhatsApp Business (Meta Cloud API) ────────────────────────
# 1. https://developers.facebook.com → App erstellen (Business-Typ)
# 2. WhatsApp → Getting Started → Temp. Access Token kopieren
#    (Für Produktion: System-User Token mit permanenter Gültigkeit)
WHATSAPP_ACCESS_TOKEN=DEIN_META_ACCESS_TOKEN

# 3. Phone Number ID aus dem WhatsApp-Dashboard
WHATSAPP_PHONE_NUMBER_ID=DEINE_PHONE_NUMBER_ID

# 4. Empfänger: Handynummern mit Ländervorwahl, OHNE + (kommagetrennt)
#    Hinweis: WhatsApp Business API schreibt in 1:1-Chats, nicht direkt
#    in Gruppen. Empfänger müssen dem Bot vorher eine Nachricht geschickt haben.
WHATSAPP_RECIPIENT_IDS=4917600000000,4917600000001

# ── Watchlist ─────────────────────────────────────────────────
WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN

# ── Alert-Schwellen ───────────────────────────────────────────
PRICE_ALERT_THRESHOLD_PCT=3.0   # Sofortiger Alert bei ±3% Tagesänderung
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
SENTIMENT_BULLISH=0.25
SENTIMENT_BEARISH=-0.25

# ── Scheduler ─────────────────────────────────────────────────
DAILY_REPORT_TIME=08:00         # Tagesbericht um 08:00 Uhr
MONITOR_INTERVAL_MIN=15         # Echtzeit-Check alle 15 Min
TZ=Europe/Berlin
